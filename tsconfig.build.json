  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}

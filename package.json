{
  "name": "@myeasyfarm/vite-plugin-icons-spritesheet",
  "version": "4.0.0-beta.8",
  "type": "module",
  "description": "Vite plugin that generates a spritesheet and types out of your icons folder.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "vite-plugin",
    "icons",
    "spritesheet",
    "vite",
    "plugin",
    "generator",
    "react",
    "angular",
    "vue",
    "remix"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "tsc": "tsc",
    "validate": "npm run lint && npm run tsc && npm run test",
    "prepare": "husky"
  },
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MyEasyFarm/vite-plugin-icons-spritesheet.git"
  },
  "bugs": {
    "url": "https://github.com/MyEasyFarm/vite-plugin-icons-spritesheet/issues"
  },
  "files": [
    "dist"
  ],
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": ">=5.2.0"
    }
  },
  "homepage": "https://github.com/MyEasyFarm/vite-plugin-icons-spritesheet#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.8",
    "tinyexec": "^1.0.2"
  },
  "peerDependencies": {
    "vite": ">=5.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/node": "^24.7.2",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vitest": "^3.2.1"
  }
}

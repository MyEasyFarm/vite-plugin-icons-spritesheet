{
  "name": "@myeasyfarm/vite-plugin-icons-spritesheet",
  "version": "4.0.0-beta.18",
  "type": "module",
  "description": "Vite plugin that generates a spritesheet and types out of your icons folder.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "icons-unused": "./dist/cli.js"
  },
  "keywords": [
    "vite-plugin",
    "icons",
    "spritesheet",
    "vite",
    "plugin",
    "generator",
    "react",
    "angular",
    "vue",
    "remix"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write .",
    "test": "node --test --test-timeout=15000",
    "test:watch": "node --test --watch --test-timeout=15000",
    "prepublishOnly": "npm run build",
    "tsc": "tsc",
    "validate": "npm run lint && npm run tsc && npm run test",
    "prepare": "husky"
  },
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MyEasyFarm/vite-plugin-icons-spritesheet.git"
  },
  "bugs": {
    "url": "https://github.com/MyEasyFarm/vite-plugin-icons-spritesheet/issues"
  },
  "files": [
    "dist"
  ],
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": "^5.2.0 || ^6.0.0 || ^7.0.0 || ^8.0.0"
    }
  },
  "homepage": "https://github.com/MyEasyFarm/vite-plugin-icons-spritesheet#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "tinyexec": "^1.1.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "vite": "^5.2.0 || ^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^24.12.4",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
